{
  "name": "echo-client",
  "version": "0.1.0",
  "description": "Echo desktop client",
  "author": "Echo",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "node -e \"console.log('TypeScript migration check: noCheck=true, so this validates parsing/module resolution, not full type safety.')\" && tsc --noEmit",
    "preview": "vite preview",
    "test": "node --import tsx --test $(find src \\( -name '*.test.ts' -o -name '*.test.tsx' -o -name '*.test.js' \\) -print)",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed --workers=1",
    "desktop:dev": "VITE_DESKTOP=true concurrently -k \"npm run dev -- --host 127.0.0.1\" \"wait-on http://localhost:5173 && ELECTRON_START_URL=http://localhost:5173 electron --no-sandbox electron/main.cjs\"",
    "desktop:build": "VITE_DESKTOP=true npm run build && electron-builder --win nsis",
    "desktop:build:linux": "VITE_DESKTOP=true npm run build && electron-builder --linux AppImage"
  },
  "dependencies": {
    "@emoji-mart/data": "^1.2.1",
    "@emoji-mart/react": "^1.1.1",
    "@hookform/resolvers": "^5.4.0",
    "dompurify": "^3.1.6",
    "emoji-mart": "^5.6.0",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.17.0",
    "marked": "^13.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.78.0",
    "socket.io-client": "^4.7.5",
    "turndown": "^7.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^24.13.1",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "concurrently": "^9.1.2",
    "electron": "^36.4.0",
    "electron-builder": "^24.13.3",
    "@vitejs/plugin-react": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vite": "^5.3.1",
    "wait-on": "^8.0.3"
  },
  "main": "electron/main.cjs",
  "build": {
    "appId": "com.echo.desktop",
    "productName": "Echo",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": ["nsis"],
      "icon": "electron/icon.png",
      "artifactName": "Echo-Setup-${version}.${ext}"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "electron/icon.png",
      "category": "Network",
      "executableName": "echo",
      "desktop": {
        "Name": "Echo",
        "Comment": "Echo team communication",
        "StartupWMClass": "Echo"
      }
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Echo"
    }
  }
}
