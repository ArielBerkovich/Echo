{
  "name": "echo-desktop",
  "productName": "Echo",
  "version": "0.2.0",
  "private": true,
  "description": "Electron desktop shell for Echo",
  "homepage": "https://github.com/ArielBerkovich/Echo",
  "author": {
    "name": "ArielBerkovich",
    "email": "34457341+ArielBerkovich@users.noreply.github.com"
  },
  "main": "main.cjs",
  "scripts": {
    "start": "electron .",
    "start:dev": "ELECTRON_START_URL=http://localhost:5173 electron .",
    "dist": "ELECTRON_BUILD=1 npm --prefix ../client run build && electron-builder"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "electron": "^37.2.6",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.echo.desktop",
    "productName": "Echo",
    "files": [
      "main.cjs",
      "preload.cjs",
      "setup.html"
    ],
    "publish": {
      "provider": "generic",
      "url": "https://updates.invalid/echo"
    },
    "extraResources": [
      {
        "from": "../client/dist",
        "to": "client-dist"
      },
      {
        "from": "../client/src/assets/echo-logo.png",
        "to": "echo-logo.png"
      }
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "../client/src/assets/echo-logo.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "../client/src/assets/echo-logo.png"
    },
    "win": {
      "target": "nsis",
      "icon": "../client/src/assets/echo-logo.png"
    },
    "nsis": {
      "deleteAppDataOnUninstall": true
    }
  }
}
