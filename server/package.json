{
  "name": "echo-server",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "backfill:activity": "node dist/backfillMessageActivity.js",
    "typecheck": "node -e \"console.log('TypeScript migration check: noCheck=true, so this validates parsing/module resolution, not full type safety.')\" && tsc --noEmit -p tsconfig.json",
    "test": "JWT_SECRET=test-secret node --import tsx --test $(find src \\( -name '*.test.ts' -o -name '*.test.js' \\) -print)"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "file-type": "^22.0.1",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.0",
    "multer": "^1.4.5-lts.1",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.13.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}
